# === Neon Database ===
# Get your connection string from https://neon.tech
# Format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# === Groq API ===
# Get your API key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# === JWT Authentication ===
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
